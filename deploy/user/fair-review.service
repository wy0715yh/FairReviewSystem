[Unit]
Description=Fair Review System (Gunicorn, user service)
After=default.target network.target

[Service]
Type=simple
WorkingDirectory=/home/user/progect/FairReviewSystem
EnvironmentFile=/home/user/progect/FairReviewSystem/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/user/progect/FairReviewSystem/scripts/run_gunicorn.sh
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=3
TimeoutStopSec=20

[Install]
WantedBy=default.target
