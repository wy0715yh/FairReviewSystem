[Unit]
Description=Fair Review System (Gunicorn)
After=network.target

[Service]
Type=simple
User=user
Group=user
WorkingDirectory=/home/user/progect/FairReviewSystem
EnvironmentFile=/home/user/progect/FairReviewSystem/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/user/progect/FairReviewSystem/scripts/run_gunicorn.sh
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=3
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
